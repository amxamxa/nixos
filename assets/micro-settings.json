{
    "autoclose": false,
    "autoindent": true,
    "autosave": 120,
    "backupdir": "$MICRO_CONFIG_HOME/backups",
    "basename": true,
    "clipboard": "external",
    "colorcolumn": 78,
    "colorscheme": "atom-dark",
    "expandtab": true,
    "fakecursor": false,
    "hlsearch": true,
    "incsearch": true,
    "initlua": true,
    "keepautoindent": true,
    "mkparents": true,
    "mouse": true,
    "permbackup": true,
    "pluginchannels": [
        "https://raw.githubusercontent.com/micro-editor/plugin-channel/master/channel.json"
    ],
    "rmtrailingws": true,
    "ruler": true,
    "savecursor": true,
    "saveundo": true,
    "scrollbar": true,
    "scrollmargin": 4,
    "scrollspeed": 4,
    "softwrap": true,
    "statusformatl": "$(filename)|$(modified)| $(status.paste)|ft:$(opt:filetype) | $(opt:fileformat) | $(opt:encoding) |($(line) of $(lines),col: $(col)  $(percentage)%",
    "statusformatr": "$(bind:ToggleKeyMenu): bindings, $(bind:ToggleHelp):help",
    "statusline": true,
    "syntax": true,
    "tabsize": 4,
    "tabhighlight": true,
    "tabreverse": false,
    "wordwrap": true
}
